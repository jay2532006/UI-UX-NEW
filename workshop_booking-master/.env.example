# ── FOSSEE Workshop Booking — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate a key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Set PRODUCTION=True in production to enable HTTPS/security headers
PRODUCTION=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Development: uses SQLite by default (no config needed)
# Production: use postgresql
DB_ENGINE=sqlite3
# DB_NAME=/absolute/path/to/db.sqlite3   # optional, defaults to BASE_DIR/db.sqlite3

# For PostgreSQL:
# DB_ENGINE=postgresql_psycopg2
# DB_NAME=workshop_db
# DB_USER=workshop_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# ── Email ─────────────────────────────────────────────────────────────────────
# Development: use console backend (prints emails to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=youremail@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# EMAIL_USE_TLS=True
# SENDER_EMAIL=noreply@fossee.in

# ── Application ───────────────────────────────────────────────────────────────
PRODUCTION_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com
SHOW_WORKSHOP_STATS=True

# ── CORS (React Frontend) ─────────────────────────────────────────────────────
# Development: auto-allows localhost:5173 when DEBUG=True (no config needed)
# Production: comma-separated allowed origins
# CORS_ALLOWED_ORIGINS=https://yourfrontend.com

# ── Security (only needed when PRODUCTION=True) ───────────────────────────────
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
